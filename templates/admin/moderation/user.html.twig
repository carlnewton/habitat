{% extends 'admin/base.html.twig' %}
{% set page_title = 'admin.moderation.users.details' | trans %}

{% block body %}
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="{{ path('app_admin_index')}}">{{ 'menus.utility.admin_dashboard.title' | trans }}</a></li>
            <li class="breadcrumb-item"><a href="{{ path('app_moderation_users')}}">{{ 'admin.moderation.title' | trans }}</a></li>
            <li class="breadcrumb-item"><a href="{{ path('app_moderation_users')}}">{{ 'admin.moderation.users.menu_title' | trans }}</a></li>
            <li class="breadcrumb-item active" aria-current="page">{{ user.username }}</li>
        </ol>
    </nav>

    <h2>{{ 'admin.moderation.users.details' | trans }}</h2>

    <div class="dropdown mb-3">
        <button class="btn btn-outline-primary dropdown-toggle" type="button" id="actions-btn" data-bs-toggle="dropdown" aria-expanded="false">
            {{ 'buttons.actions' | trans }}
        </button>
        <ul class="dropdown-menu" id="actions-menu" aria-labelledby="actions-btn">
            <li>
                {% if user.posts|length > 0 %}
                    <a href="{{ path('app_moderation_posts', { user: user.id }) }}" class="dropdown-item">{{ 'menus.contextual.view_posts.title' | trans }}</a>
                {% endif %}
            </li>
            <li>
                {% if user.comments|length > 0 %}
                    <a href="{{ path('app_moderation_comments', { user: user.id }) }}" class="dropdown-item">{{ 'menus.contextual.view_comments.title' | trans }}</a>
                {% endif %}
            </li>
            {% if is_granted('ROLE_SUPER_ADMIN') %}
                <li>
                    <form class="action-item-form" method="post" action="{% if 'ROLE_MODERATOR' in user.roles %}{{ path('app_moderation_users_demote') }}{% else %}{{ path('app_moderation_users_promote') }}{% endif %}">
                        <input name="items" type="hidden" value="{{ user.id }}"/>
                        <input type="hidden" name="token" value="{{ csrf_token('admin') }}">
                        <button type="submit" class="dropdown-item checkbox-action">{% if 'ROLE_MODERATOR' in user.roles %}{{ 'admin.actions.demote.title' | trans }}{% else %}{{ 'admin.actions.promote.title' | trans }}{% endif %}</button>
                    </form>
                </li>
            {% endif %}
            <li>
                <form class="action-item-form" method="post" action="{% if user.frozen %}{{ path('app_moderation_users_unfreeze') }}{% else %}{{ path('app_moderation_users_freeze') }}{% endif %}">
                    <input name="items" type="hidden" value="{{ user.id }}"/>
                    <input type="hidden" name="token" value="{{ csrf_token('admin') }}">
                    <button type="submit" class="dropdown-item checkbox-action">{% if user.frozen %}{{ 'admin.actions.unfreeze' | trans }}{% else %}{{ 'admin.actions.freeze.title' | trans }}{% endif %}</button>
                </form>
            </li>
            <li>
                <form class="action-item-form" method="post" action="{{ path('app_moderation_users_ban') }}">
                    <input name="items" type="hidden" value="{{ user.id }}"/>
                    <input type="hidden" name="token" value="{{ csrf_token('admin') }}">
                    <button type="submit" class="dropdown-item checkbox-action">{{ 'admin.actions.ban.title' | trans }}</button>
                </form>
            </li>
        </ul>
    </div>

    <table class="table">
        <tbody>
            <tr>
                <th>{{ 'fields.username.title' | trans }}</th>
                <td>{{ user.username }}</td>
            </tr>
            <tr>
                <th>{{ 'fields.email_address.title' | trans}}</th>
                <td>{{ user.emailaddress }}</td>
            </tr>
            <tr>
                <th>{{ 'fields.created.title' | trans }}</th>
                <td>{{ user.created|local_date }}</td>
            </tr>
            <tr>
                <th>{{ 'admin.actions.freeze.freeze_status' | trans }}</th>
                <td>
                    {% if user.frozen %}
                    {{ 'admin.actions.freeze.currently_frozen' | trans }} {{ user.frozenLog.unfreezeDate|time_diff }}.
                    {% else %}
                        {{ 'admin.actions.freeze.not_frozen' | trans }}
                    {% endif %}
                </td>
            </tr>
            <tr>
                <th>{{ 'fields.posts.title' | trans }}</th>
                <td>
                    <a class="btn btn-link{% if user.posts|length == 0 %} disabled{% endif %}" href="{{ path('app_moderation_posts', { user: user.id }) }}">
                        {{ user.posts|length }}
                    </a>
                </td>
            </tr>
            <tr>
                <th>{{ 'fields.comments.title' | trans }}</th>
                <td>
                    <a class="btn btn-link{% if user.comments|length == 0 %} disabled{% endif %}" href="{{ path('app_moderation_comments', { user: user.id }) }}">
                        {{ user.comments|length }}
                    </a>
                </td>
            </tr>
        </tbody>
    </table>
{% endblock %}
