{% extends 'base.html.twig' %}
{% set page_title = 'post.create' | trans %}

{% block stylesheets %}
    {{ parent() }}
    {{ encore_entry_link_tags('create_post') }}
{% endblock %}

{% block body %}
    <h1 class="visually-hidden">{{ 'post.create' | trans }}</h1>
    <form id="post-form" method="post" action="{{ path('app_create_post') }}" enctype="multipart/form-data">
        <div class="form-floating mb-3">
            <input type="text" class="form-control form-control-lg{% if errors.title is defined %} is-invalid{% endif %}" name="title" placeholder="{{ 'fields.title.title' | trans }}" value="{% if values.title is defined %}{{ values.title }}{% endif %}" data-test="title">
            <label for="title">{{ 'fields.title.title' | trans }}</label>
            {% if errors.title is defined %}
                <div class="invalid-feedback" data-test="title-errors">
                    {% for errorMessage in errors.title %}
                        <p>{{ errorMessage }}</p>
                    {% endfor %}
                </div>
            {% endif %}
        </div>
        <div class="form-floating mb-3">
            <label for="body" class="form-label visually-hidden">{{ 'fields.body.title' | trans }}</label>
            <div class="card{% if errors.body is defined %} border-danger{% endif %}">
                <div class="card-header">
                    <button type="button" class="ttBtnA btn"><i class="bi bi-link"></i></button>
                </div>
                <div class="card-body editor"></div>
            </div>
            {% if errors.body is defined %}
                <div class="text-danger">
                    {% for errorMessage in errors.body %}
                        <p>{{ errorMessage }}</p>
                    {% endfor %}
                </div>
            {% endif %}
            <input type="hidden" name="body" id="ttContent" value="{% if values.body is defined %}{{ values.body }}{% endif %}">
        </div>
        <div class="form-floating mb-3{% if categories|length == 1 %} d-none{% endif %}">
            <select class="form-select{% if errors.category is defined %} is-invalid{% endif %}" name="category" id="category" aria-label="{{ 'fields.category.title' | trans }}">
                {% for category in categories %}
                    <option{% if (values.category is defined and values.category == category.id) or (values.category is not defined and app.request.query.get('category') == category.id) %} selected{% endif %} value="{{ category.id }}" data-location="{{ category.location.label|lower }}">{{ category.name }}</option>
                {% endfor %}
            </select>
            <label for="category">{{ 'fields.category.title' | trans }}</label>
            {% if errors.category is defined %}
                <div class="invalid-feedback">
                    {% for errorMessage in errors.category %}
                        <p>{{ errorMessage }}</p>
                    {% endfor %}
                </div>
            {% endif %}
        </div>
        <div class="dropzone mb-3"></div>
        <input type="hidden" name="attachmentIds" id="attachmentIds" value="{% if values.attachmentIds is defined %}{{ values.attachmentIds }}{% endif %}">
        <button class="btn btn-outline-primary mb-3" id="add-location-btn" type="button">{{ 'buttons.add_a_location' | trans }}</button>
        <div id="location-card" class="card mb-3{% if errors.location is defined %} border-danger{% endif %}">
            <div class="card-header">
                {{ 'fields.location.title' | trans }}
                <button type="button" class="btn-close float-end" id="remove-location-btn" title="{{ 'buttons.remove_location' | trans }}" aria-label="{{ 'buttons.remove_location' | trans }}"></button>
            </div>
            <div class="card-body ratio ratio-16x9">
                <div id="map" data-center="{{ setting('locationLatLng') }}" data-zoom="{{ setting('locationZoom') }}" data-radius="{{ setting('locationRadiusMeters') }}"></div>
            </div>
            <div class="card-body text-white bg-danger text-center fw-bold d-none" id="bounds-warning">
                {{ 'map.validations.out_of_bounds' | trans }}
            </div>
            <div class="card-footer">
                <div class="row">
                    <div class="col-12 gx-2 d-flex align-items-center">
                        <button type="button" class="btn btn-outline-secondary get-location float-start" title="{{ 'buttons.show_current_location' | trans }}"><i class="bi bi-crosshair2"></i></button>
                        <span class="ms-2 text-secondary">{{ 'map.warnings.home_address' | trans }}</span>
                    </div>
                </div>
            </div>
        </div>
        {% if errors.location is defined %}
            <div class="text-danger">
                {% for errorMessage in errors.location %}
                    <p>{{ errorMessage }}</p>
                {% endfor %}
            </div>
        {% endif %}
        <input type="hidden" name="locationLatLng" id="locationLatLng" value="{% if values.locationLatLng is defined %}{{ values.locationLatLng }}{% endif %}">
        <input type="hidden" name="token" value="{{ csrf_token('post') }}">
        <div class="d-grid gap-2">
            <button type="button" id="submit-post-btn" class="btn btn-primary btn-lg" data-test="submit">{{ 'buttons.submit_post' | trans }}</button>
        </div>
    </form>
    {% include 'partials/tt_editor/link_modal.html.twig' %}
    <div id="posting" class="text-center text-secondary py-5 d-none">
        <div class="spinner-border my-5" role="status"></div>
        <p class="fs-3">{{ 'post.posting' | trans }}</p>
    </div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    {{ encore_entry_script_tags('create_post') }}
    {{ encore_entry_script_tags('tt_editor') }}
{% endblock %}
