{% extends 'setup/base.html.twig' %}

{% block body %}
    <h1 class="display-5 fw-bold">Habitat</h1>
    <div class="mt-3">
        <i class="bi bi-circle-fill px-2 text-primary"></i>
        <i class="bi bi-circle px-2 text-primary" style="--bs-text-opacity: .5;"></i>
        <i class="bi bi-circle px-2 text-primary" style="--bs-text-opacity: .5;"></i>
        <i class="bi bi-circle px-2 text-primary" style="--bs-text-opacity: .5;"></i>
        <i class="bi bi-circle px-2 text-primary" style="--bs-text-opacity: .5;"></i>
        <i class="bi bi-circle px-2 text-primary" style="--bs-text-opacity: .5;"></i>
    </div>
    <div class="col-lg-6 col-md-8 mx-auto">
        <p class="lead mb-4">{{ 'setup.select_language.title' | trans }}</p>
        <form class="text-start" method="post" action="{{ path('app_setup_language') }}">
            {% for message in app.flashes('warning') %}
                <div class="alert alert-danger" role="alert">
                    {{ message }}
                </div>
            {% endfor %}
            <div class="row mb-3">
                <select class="form-select form-select-lg{% if errors.language is defined %} is-invalid{% endif %}" name="language" id="language" aria-label="{{ 'fields.language.title' | trans }}" data-test="language">
                    {% for language_code, language_name in languages %}
                        <option{% if (values.language is defined and values.language == language_code) or (values.language is not defined and app.request.query.get('language') == language_code) %} selected{% endif %} value="{{ language_code }}">{{ language_name }}</option>
                    {% endfor %}
                </select>

                {% if errors.language is defined %}
                    <div class="invalid-feedback" data-test="invalidLanguage">
                        {% for errorMessage in errors.language %}
                            <p>{{ errorMessage }}</p>
                        {% endfor %}
                    </div>
                {% endif %}
            </div>
            <div class="text-center">
                <button class="btn btn-primary btn-lg" data-test="submit">{{ 'buttons.continue' | trans }}</button>
            </div>
            <input type="hidden" name="token" value="{{ csrf_token('setup') }}">
        </form>
    </div>
{% endblock %}
